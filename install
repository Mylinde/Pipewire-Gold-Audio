#!/bin/bash

set -e  # Exit script on error

# Pick sudo or doas. Override with OVERRIDE_ELEVATION=sudo|doas
choose_elev() {
  if [ "${OVERRIDE_ELEVATION:-}" = "sudo" ]; then
    echo "sudo"; return
  elif [ "${OVERRIDE_ELEVATION:-}" = "doas" ]; then
    echo "doas"; return
  fi
  if command -v doas >/dev/null 2>&1; then
    echo "doas"
  elif command -v sudo >/dev/null 2>&1; then
    echo "sudo"
  else
    echo "Error: Neither sudo nor doas found in PATH." >&2
    exit 1
  fi
}

# Choose elevation on demand (OVERRIDE_ELEVATION can change at runtime)
get_elev() { choose_elev; }

ELEV="$(get_elev)"

if [ $# -ne 1 ]; then
    echo "Usage: $0 [user|uninstall]"
    echo "  user      - Installation for current user"
    echo "  uninstall - Uninstallation"
    exit 1
fi

case "$1" in
    user)
        echo "=== PipeWire Installation for User ==="
        
        # Create directories
        mkdir -p ~/.config/pipewire/hesuvi
        mkdir -p ~/.config/pipewire/pipewire.conf.d
        
        # Check if pipewire.conf already exists
        if [ -f ~/.config/pipewire/pipewire.conf.d/pipewire.conf ]; then
            echo "⚠ Found existing pipewire.conf in ~/.config/pipewire/pipewire.conf.d/"
            read -r -p "Should it be overwritten? [y/N] " response
            if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
                echo "Installing pipewire.conf..."
                install -D ./pipewire.conf.d/pipewire.conf ~/.config/pipewire/pipewire.conf.d/
            else
                echo "Keeping existing pipewire.conf"
            fi
        else
            echo "Installing pipewire.conf..."
            install -D ./pipewire.conf.d/pipewire.conf ~/.config/pipewire/pipewire.conf.d/
        fi
        
        # Always install filter configurations and HeSuVi files
        echo "Installing filter configurations..."
        install -D ./pipewire.conf.d/sink-eq10-5.1.conf ~/.config/pipewire/pipewire.conf.d/
        install -D ./pipewire.conf.d/sink-eq10-wide.conf ~/.config/pipewire/pipewire.conf.d/
        
        echo "Installing HeSuVi files..."
        install -D ./hesuvi/* ~/.config/pipewire/hesuvi/
        
        # Get current username
        current_user=$USER
        
        # Adjust HeSuVi file path with current username (BEFORE target.object)
        sed -i "s|hesuvi.wav|/home/$current_user/.config/pipewire/hesuvi/hesuvi.wav|g" ~/.config/pipewire/pipewire.conf.d/sink-eq10-5.1.conf
        
        # Get target.object and validate it
        target_object=$(wpctl status | grep '0. Audio/Sink' | awk '{print $3}')
        
        # Check if target_object is empty or contains filter configuration names
        if [ -z "$target_object" ]; then
            echo "✗ Error: Could not detect audio sink"
            echo "Please manually determine the sink name:"
            echo "  1) wpctl status"
            echo "  2) wpctl inspect <ID>"
            echo "  3) Look for 'node.name' with 'alsa_output'"
            echo "Then edit the configuration files and set 'target.object' manually."
            exit 1
        fi
        
        if [ "$target_object" = "effect_input.hesuvi_5.1" ] || [ "$target_object" = "effect_input.eq6" ]; then
            echo "✗ Error: Detected PipeWire filter configuration instead of actual audio sink"
            echo "This suggests PipeWire filters are already loaded or misconfigured."
            echo ""
            echo "To fix this:"
            echo "  1) Check existing configurations: ls ~/.config/pipewire/pipewire.conf.d/"
            echo "  2) Run 'wpctl status' and look for the actual hardware sink (alsa_output...)"
            echo "  3) If unsure, restart PipeWire: systemctl --user restart pipewire"
            echo "  4) Then run this script again"
            exit 1
        fi
        
        sed -i "s|target\.object = .*|target.object = \"$target_object\"|" ~/.config/pipewire/pipewire.conf.d/sink-eq10-5.1.conf
        sed -i "s|target\.object = .*|target.object = \"$target_object\"|" ~/.config/pipewire/pipewire.conf.d/sink-eq10-wide.conf

        echo "✓ Konfigurationsdateien installiert"
        echo "✓ HeSuVi-Pfade angepasst für Benutzer: $current_user"
        echo "✓ target.object aktualisiert: $target_object"
        
        # GUI Installation
        echo ""
        echo "=== GUI-Installation ==="
        gui_dir="$HOME/.local/share/pipewire"
        mkdir -p "$gui_dir"
        
        # Install GUI files
        echo "Installiere GUI-Dateien..."
        install -D ./gui.py "$gui_dir/"
        install -D ./config.json "$gui_dir/"
        install -D ./babel.cfg "$gui_dir/"
        install -D ./babel_config.py "$gui_dir/"
        install -D ./gunicorn_config.py "$gui_dir/"
        cp -r ./templates "$gui_dir/"
        cp -r ./static "$gui_dir/"
        cp -r ./translations "$gui_dir/"
        echo "✓ GUI-Dateien installiert"
        
        # Python virtual environment setup
        echo ""
        echo "=== Python-Umgebung einrichten ==="
        venv_dir="$gui_dir/venv"
        
        if [ -d "$venv_dir" ]; then
            echo "Virtuelle Umgebung existiert bereits, wird übersprungen..."
        else
            echo "Erstelle virtuelle Umgebung in $venv_dir..."
            python3 -m venv "$venv_dir"
            echo "✓ Virtuelle Umgebung erstellt"
        fi
        
        # Activate venv and install requirements
        echo "Installiere Python-Abhängigkeiten..."
        . "$venv_dir/bin/activate"
        pip install --upgrade pip > /dev/null 2>&1
        
        if [ -f ./requirements.txt ]; then
            pip install -r ./requirements.txt
            echo "✓ Python-Abhängigkeiten installiert"
        else
            echo "⚠ requirements.txt nicht gefunden"
        fi
        deactivate
        
        # Systemd services installation
        echo ""
        echo "=== Systemd-Dienste installieren ==="
        systemd_user_dir="$HOME/.config/systemd/user"
        mkdir -p "$systemd_user_dir"
        
        # Copy service files and update paths
        if [ -f ./systemd-services/pipewire-eq.service ]; then
            echo "Installiere pipewire-eq.service..."
            sed "s|WorkingDirectory=.*|WorkingDirectory=$gui_dir|g" ./systemd-services/pipewire-eq.service > "$systemd_user_dir/pipewire-eq.service"
            echo "✓ pipewire-eq.service installiert"
        else
            echo "⚠ pipewire-eq.service nicht gefunden"
        fi
        
        if [ -f ./systemd-services/pipewire-listen.service ]; then
            echo "Installiere pipewire-listen.service..."
            cp ./systemd-services/pipewire-listen.service "$systemd_user_dir/"
            echo "✓ pipewire-listen.service installiert"
        else
            echo "⚠ pipewire-listen.service nicht gefunden"
        fi
        
        # Reload systemd
        echo "Systemd neu laden..."
        systemctl --user daemon-reload
        
        # Enable services
        echo "Aktiviere Systemd-Dienste..."
        systemctl --user enable pipewire-eq.service
        systemctl --user enable pipewire-listen.service
        echo "✓ Dienste aktiviert"
        
        # Add user to pipewire group
        if getent group pipewire > /dev/null; then
            echo ""
            echo "Füge Benutzer zur 'pipewire'-Gruppe hinzu..."
            "$ELEV" usermod -a -G pipewire $USER
            echo "⚠ Bitte melden Sie sich ab und wieder an, damit die Gruppenänderungen wirksam werden"
        else
            echo "⚠ Gruppe 'pipewire' existiert nicht"
        fi
        echo ""
        echo "✓ Installation abgeschlossen"
        ;;
    
    uninstall)
        echo "=== PipeWire Deinstallation ==="
        
        # Disable and stop systemd services
        echo "Deaktiviere Systemd-Dienste..."
        systemctl --user stop pipewire-eq.service 2>/dev/null || true
        systemctl --user stop pipewire-listen.service 2>/dev/null || true
        systemctl --user disable pipewire-eq.service 2>/dev/null || true
        systemctl --user disable pipewire-listen.service 2>/dev/null || true
        rm -f ~/.config/systemd/user/pipewire-eq.service
        rm -f ~/.config/systemd/user/pipewire-listen.service
        systemctl --user daemon-reload
        echo "✓ Systemd-Dienste entfernt"
        
        # Remove GUI installation
        gui_dir="$HOME/.local/share/pipewire"
        if [ -d "$gui_dir" ]; then
            echo "Entferne GUI-Installation..."
            rm -rf "$gui_dir"
            echo "✓ GUI und virtuelle Umgebung entfernt"
        fi
        
        # Remove user installation
        if [ -d ~/.config/pipewire ]; then
            echo "Entferne Benutzerkonfiguration..."
            rm -rf ~/.config/pipewire/hesuvi
            rm -f ~/.config/pipewire/pipewire.conf.d/sink-eq10-5.1.conf
            rm -f ~/.config/pipewire/pipewire.conf.d/sink-eq10-wide.conf
            echo "✓ Filterkonfigurationen entfernt"
            
            # Check if pipewire.conf exists and ask before removing
            if [ -f ~/.config/pipewire/pipewire.conf.d/pipewire.conf ]; then
                echo "⚠ pipewire.conf existiert in ~/.config/pipewire/pipewire.conf.d/"
                read -r -p "Soll diese gelöscht werden? [y/N] " response
                if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
                    rm -f ~/.config/pipewire/pipewire.conf.d/pipewire.conf
                    echo "✓ pipewire.conf gelöscht"
                else
                    echo "Behalte pipewire.conf"
                fi
            fi
            
            echo "⚠ Entferne Benutzer aus 'pipewire'-Gruppe..."
            "$ELEV" usermod -r -G pipewire $USER 2>/dev/null || true
            echo "✓ Benutzer aus 'pipewire'-Gruppe entfernt"
        fi
        echo ""
        echo "✓ Deinstallation abgeschlossen"
        ;;
    *)
        echo "Usage: $0 [user|uninstall]"
        echo "  user      - Installation for current user"
        echo "  uninstall - Uninstallation"
        exit 1
        ;;
esac
